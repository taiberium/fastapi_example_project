# Copy to `.env` and fill in real values. `.env` is gitignored — never commit real secrets.
# All variables are read by app/core/settings.py (prefix APP_). Anything left unset
# falls back to the defaults defined in Settings.

# --- Database ---
# DB is derived from APP_ENV: local -> sqlite, stg/prod -> postgresql.
# Leave APP_DATABASE_URL unset to use the derived URL; set it only to override
# (e.g. CI). The sqlite path below is used only when APP_ENV=local.
# APP_DATABASE_URL=
APP_SQLITE_PATH=sqlite:///mydatabase.db

# Postgres connection (used when APP_ENV=stg|prod). Use a strong, unique
# password — never default creds. USER + PASSWORD are required for stg/prod.
APP_POSTGRES_HOST=localhost
APP_POSTGRES_PORT=5432
APP_POSTGRES_USER=
APP_POSTGRES_PASSWORD=
APP_POSTGRES_DB=app

# --- App ---
APP_APP_TITLE=Fast API Example App
APP_LOG_LEVEL=INFO

# --- Server ---
APP_ENV=local          # local | stg | prod  (prod requires SECRET_KEY + GOOGLE_CLIENT_ID below)
APP_SERVER_HOST=0.0.0.0
APP_SERVER_PORT=8000
# Allowed browser origins for CORS (JSON list). Set to your frontend origin in prod.
APP_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- Observability (OpenTelemetry OTLP export) ---
# Off by default. Set true to ship traces/metrics/logs to an OTLP/HTTP collector.
APP_OTEL_ENABLED=false
APP_OTEL_SERVICE_NAME=fastapi-example
# OTLP/HTTP base URL (no /v1/... suffix). Grafana-stack collector example:
#   APP_OTEL_EXPORTER_OTLP_ENDPOINT=http://49.12.196.176:4328
APP_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# --- Auth (Google OAuth2 -> app JWT) ---
# Google OAuth client id from Google Cloud Console (looks like below):
APP_GOOGLE_CLIENT_ID=1234567890-abc123def456ghi789jkl012mno345pq.apps.googleusercontent.com

# JWT signing secret. Generate a strong random one, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
APP_SECRET_KEY=qZ8Jr2_replace_me_with_a_64char_random_string_xV3nKp9wLs5dHtB1aFcEoY

APP_ALGORITHM=HS256
APP_ACCESS_TOKEN_EXPIRE_MINUTES=1440
